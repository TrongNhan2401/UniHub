{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "Security": {
    "MessageEncryptionKey": "Your-Super-Secret-32-Char-Key-!!!"
  },
  "Jwt": {
    "Issuer": "UniHub.Api",
    "Audience": "UniHub.Client",
    "Key": "REPLACE_WITH_SECRET_MIN_32_CHARS"
  },
  "ClientUrl": "http://localhost:5173",
  "ConnectionStrings": {
    "Default": "Host=REPLACE_WITH_DB_HOST;Port=6543;Database=postgres;Username=REPLACE_WITH_DB_USERNAME;Password=REPLACE_WITH_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true",
    "Migration": "Host=REPLACE_WITH_DB_HOST;Port=5432;Database=postgres;Username=postgres;Password=REPLACE_WITH_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },
  "AllowedHosts": "*"
}
